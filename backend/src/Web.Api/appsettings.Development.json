{
"ConnectionStrings": {
  "Database": "Host=localhost;Port=5432;Database=clean-architecture;Username=postgres;Password=postgres;Include Error Detail=true"
},
"Serilog": {
  "Using": [
    "Serilog.Sinks.Console",
    "Serilog.Sinks.Seq"
  ],
  "MinimumLevel": {
    "Default": "Information",
    "Override": {
      "Microsoft": "Information"
    }
  },
  "WriteTo": [
    { "Name": "Console" },
    {
      "Name": "Seq",
      "Args": { "ServerUrl": "http://localhost:8081" }
    }
  ],
  "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
},
"Jwt": {
  "Secret": "super-duper-secret-value-that-should-be-in-user-secrets-min-32-chars",
  "Issuer": "onex-api",
  "Audience": "onex-clients",
  "AccessTokenExpirationMinutes": 20,
  "RefreshTokenExpirationDays": 7
},
"Email": {
  "SmtpHost": "localhost",
  "SmtpPort": 1025,
  "UseSsl": false,
  "FromEmail": "noreply@onex.local",
  "FromName": "ONEX Development",
  "AppBaseUrl": "http://localhost:3000",
  "EnableSending": true
},
"StressDetection": {
  "BaseUrl": "http://localhost:8000",
  "ApiKey": "",
  "TimeoutSeconds": 10,
  "PredictPath": "/predict-stress",
  "HealthPath": "/health"
},
"AgentWebhook": {
  "Secret": "dev-webhook-secret-change-me",
  "MaxSkewSeconds": 600,
  "SignatureHeader": "X-Webhook-Signature",
  "TimestampHeader": "X-Webhook-Timestamp"
}
}
