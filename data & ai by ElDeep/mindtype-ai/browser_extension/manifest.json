{
  "manifest_version": 3,
  "name": "MindType AI Keystroke Agent",
  "version": "1.0",
  "description": "Capture browser typing dynamics and send features to MindType AI backend.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["http://localhost:8000/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "MindType AI Agent",
    "default_popup": "popup.html"
  }
}
